{
  "name": "artha-v4",
  "version": "1.0.0",
  "private": true,
  "displayName": "PIE — Personal Investment Engine",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs src/api/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/api/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run tests/stress",
    "test:visual": "playwright test --config playwright.config.ts",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint: not configured')\"",
    "test:stress:run": "npx tsx tests/stress/multiYear.test.ts",
    "db:migrate:reset": "prisma migrate reset --force --skip-seed",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy",
    "db:deploy:all": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/migrate-all.ts",
    "migrate:secrets": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/migrate-plaintext-secrets.ts",
    "migrate:v52": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/migrate-settings-to-v52.ts",
    "v52-smoke": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/v52-smoke.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "PIE (Personal Investment Engine) — personal wealth dashboard and APIs (package id remains artha-v4 for compatibility).",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^6.19.3",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "echarts": "^5.6.0",
    "express": "^5.2.1",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/nodemailer": "^6.4.16",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
