# PIE V6 — production environment template
# Copy to .env on the production host and fill in the values.
# Never commit the resulting .env to git. The values below are illustrative.

# ───── Required ─────────────────────────────────────────────
NODE_ENV=production
PORT=3002

# Personal database (Postgres). Use a dedicated, non-root role.
DATABASE_URL=postgresql://pie_app:CHANGE-ME@127.0.0.1:5432/pie_personal

# Demo database — MUST differ from DATABASE_URL. Demo mode wipes/reseeds it
# whenever it's toggled on; never point this at real data.
DATABASE_URL_DEMO=postgresql://pie_app:CHANGE-ME@127.0.0.1:5432/pie_demo

# Random 32+ char string. Signs the dashboard session cookie.
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE-ME-32-PLUS-RANDOM-CHARS

# Public URL behind your reverse proxy (Caddy/NGINX). Used in OAuth redirects
# and outbound emails. NO trailing slash.
PIE_PUBLIC_URL=https://pie.example.com

# ───── Strongly recommended ────────────────────────────────
# Where the AES-256-GCM key file lives. Back this file up — losing it
# means losing your encrypted secrets.
PIE_SECRET_KEY_PATH=/var/lib/pie/secret.key

# ───── Auth (UI-driven; see Settings → App preferences) ────
# Optional fallback bootstrap key if you don't want to set one in the UI.
# Leave blank in production once a UI bootstrap phrase is set.
# PIE_AUTH_BOOTSTRAP_KEY=

# Hard kill switch: set to 0 only if you lock yourself out.
# Otherwise leave unset — dashboard auth lives in AppSettings.
# PIE_DASHBOARD_AUTH=

# ───── Optional integrations (can also be set via Settings UI) ──
# AI providers — recommended via Settings → Integrations instead of env.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Telegram bot, FX api, etc. (optional)
# TELEGRAM_BOT_TOKEN=
# EXCHANGERATE_API_KEY=

# ───── Hardening flags ─────────────────────────────────────
# Strict TLS verification on outbound SMTP. Set to 1 ONLY for local
# self-signed test relays — never in production.
# PIE_SMTP_INSECURE_TLS=0

# /healthz fails when no AI provider is enabled. Off by default; set to 1
# if your monitor should treat missing AI as a degraded state.
# PIE_HEALTHZ_STRICT_AI=0
