# ARTHA V4 — production environment (copy to /opt/artha/.env on the server)
# Never commit real secrets.
#
# Required
# --------
# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/artha_v4?schema=public"
#
# Node
NODE_ENV=production
PORT=3002
#
# Optional — integrations
# ------------------------
# AI (at least one for full /api/intelligence/ask responses)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
#
# Optional — email (Settings UI can also store SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
#
# Optional — Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
#
# Optional — FX
EXCHANGE_RATE_API_KEY=
#
# Notes
# ----
# - Rotate DB password after first boot; use strong secrets.
# - Restrict .env file permissions: chmod 600 .env
# - Back up DATABASE_URL in your password manager.
