# Copy to .env and adjust. Do not commit real secrets.

NODE_ENV=development
PORT=3002

# PostgreSQL (local). No-Docker Windows: double-click start-artha.bat — portable PG
# at C:\Projects\pgsql, dev cluster on port 5544 (see docs in start-artha.bat header).
# Manual create DB:  psql -U postgres -h 127.0.0.1 -p 5544 -c "CREATE DATABASE artha_v4;"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5544/artha_v4?schema=public"

# Isolated database when demo mode is on (see prismaProvider / wipeAndSeedDemoDb).
DATABASE_URL_DEMO="postgresql://postgres:postgres@127.0.0.1:5544/artha_v4_demo?schema=public"

# Set to 1 only when Postgres is running — enables Supertest API suites that need the DB.
# ARTHA_TEST_DB_LIVE=1

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EXCHANGE_RATE_API_KEY=
SESSION_SECRET=change-me-to-random-string
ADMIN_PIN=

# Dashboard login: turn on in Settings → App preferences (stored in AppSettings.dashboardAuthEnabled).
# PIE_DASHBOARD_AUTH=0 forces login off if you lock yourself out (recovery only).
# First password on /login.html: use bootstrap phrase saved in Settings (recommended) OR set this env value once.
PIE_DASHBOARD_AUTH=
PIE_AUTH_BOOTSTRAP_KEY=

# Gmail OAuth (optional): send via Gmail API over HTTPS — avoids blocked SMTP.
# You can instead save Client ID + Client Secret on Settings → Integrations → SMTP (n8n-style).
# PIE_PUBLIC_URL: optional if you always open the app from the same origin (PIE infers redirect from the request).
# Google Cloud → Credentials → OAuth 2.0 Client ID (Web). Authorized redirect URI must match meta / Copy on SMTP card.
PIE_PUBLIC_URL=http://127.0.0.1:3002
PIE_GOOGLE_OAUTH_CLIENT_ID=
PIE_GOOGLE_OAUTH_CLIENT_SECRET=
